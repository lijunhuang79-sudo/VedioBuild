# ============ 数据库 ============
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_video_factory

# ============ Redis ============
REDIS_URL=redis://localhost:6379/0

# ============ JWT 认证 ============
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ============ 对象存储 (MinIO/S3) ============
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-videos
S3_REGION=us-east-1

# ============ DeepSeek API (视频文案生成) ============
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ============ 阿里云 智能语音 TTS（真人配音） ============
# 控制台创建项目后：项目 AppKey + 访问控制 AccessKey
ALIYUN_ACCESS_KEY_ID=xxx
ALIYUN_ACCESS_KEY_SECRET=xxx
ALIYUN_NLS_APPKEY=xxx
ALIYUN_NLS_REGION=cn-shanghai
# 真人化：语速 -85、音调 14、音量 60；多情感音色 zhimi_emo 更自然（需控制台开通）
ALIYUN_TTS_SPEECH_RATE=-85
ALIYUN_TTS_PITCH_RATE=14
ALIYUN_TTS_VOLUME=60
# ALIYUN_TTS_VOICE=zhimi_emo

# ============ 阿里万相 2.6 文生视频（可选试用） ============
# 百炼 API Key：https://help.aliyun.com/zh/model-studio/get-api-key
# DASHSCOPE_API_KEY=sk-xxx
# USE_WANXIANG_VIDEO=true

# ============ 备用: OpenAI 兼容 (可选) ============
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# ============ 支付 (Stripe) ============
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_STUDIO=price_xxx

# ============ 应用配置 ============
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
